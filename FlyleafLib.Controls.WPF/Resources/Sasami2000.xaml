<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <!-- Classic Windows 2000 Palette -->
    <Color x:Key="Sasami2000.Color.Background">#D4D0C8</Color>
    <Color x:Key="Sasami2000.Color.Light">#FFFFFF</Color>
    <Color x:Key="Sasami2000.Color.Dark">#808080</Color>
    <Color x:Key="Sasami2000.Color.Shadow">#404040</Color>
    <Color x:Key="Sasami2000.Color.Accent">#000080</Color>
    <Color x:Key="Sasami2000.Color.Text">#000000</Color>

    <SolidColorBrush x:Key="Sasami2000.Brush.Background" Color="{StaticResource Sasami2000.Color.Background}"/>
    <SolidColorBrush x:Key="Sasami2000.Brush.Accent" Color="{StaticResource Sasami2000.Color.Accent}"/>
    <SolidColorBrush x:Key="Sasami2000.Brush.Text" Color="{StaticResource Sasami2000.Color.Text}"/>

    <!-- Classic Bevel Border Style -->
    <Style x:Key="Sasami2000.BorderStyle.Outset" TargetType="Border">
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="{StaticResource Sasami2000.Color.Light}" Offset="0"/>
                    <GradientStop Color="{StaticResource Sasami2000.Color.Light}" Offset="0.5"/>
                    <GradientStop Color="{StaticResource Sasami2000.Color.Shadow}" Offset="0.5"/>
                    <GradientStop Color="{StaticResource Sasami2000.Color.Shadow}" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Sasami2000.BorderStyle.Inset" TargetType="Border">
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="{StaticResource Sasami2000.Color.Shadow}" Offset="0"/>
                    <GradientStop Color="{StaticResource Sasami2000.Color.Shadow}" Offset="0.5"/>
                    <GradientStop Color="{StaticResource Sasami2000.Color.Light}" Offset="0.5"/>
                    <GradientStop Color="{StaticResource Sasami2000.Color.Light}" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
